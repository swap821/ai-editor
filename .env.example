# ── AI OS (aios) environment overrides ───────────────────────────────────────
# Copy to `.env` and uncomment what you want to change. Every value is OPTIONAL:
# sensible local-first defaults live in aios/config.py, and anything left unset
# falls back to those. `.env` is gitignored — never commit real secrets.
#
# This file aims to document every AIOS_*/OLLAMA_HOST var aios/config.py reads.
# If you add a new _env_*() call to config.py, add its line here too.

# --- Paths ---------------------------------------------------------------
# AIOS_DATA_DIR=C:\Users\kumar\ai-editor\data
# AIOS_ROLLBACK_DIR=<AIOS_DATA_DIR>/rollback
# AIOS_COUNCIL_RUNTIME_DIR=<AIOS_DATA_DIR>/council_runtime
# AIOS_COUNCIL_WORKSPACE_ROOT=<AIOS_DATA_DIR>/council_workspace

# --- Council Runtime (King/Queen/Worker mission orchestration) -----------
# AIOS_COUNCIL_REASONING=true          # LLM-backed Queen reasoning (degrades gracefully without an LLM client)
# AIOS_COUNCIL_CRITIQUE=false          # opt-in second-order "was verification actually sufficient" check
# AIOS_COUNCIL_KING_REASONING=false    # opt-in LLM King that enriches the recommendation (strengthen-only)
# AIOS_VERIFICATION_PROMOTION_FLOOR=STRONG   # minimum verification strength eligible to calibrate future behavior
# AIOS_WORKER_REASONING=false          # opt-in LLM-driven worker (self-correcting); default is the deterministic CI-safe worker
# AIOS_WORKER_MAX_REPAIRS=2            # max self-correction retries after a failed verification
# AIOS_WORKER_MAX_FILE_BYTES=1000000   # DoS guard on LLM-proposed file content size
# AIOS_COUNCIL_ORIGINATION=true        # allow /api/v1/council/originate to accept chat-originated missions
# AIOS_COUNCIL_MAX_CONCURRENT_WORKERS=4   # global cap on concurrent worker subprocesses

# --- Embeddings ------------------------------------------------------------
# AIOS_EMBEDDING_MODEL=all-MiniLM-L6-v2
# AIOS_EMBEDDING_DIM=384

# --- Hybrid retrieval weights  (R = a*BM25 + b*FAISS + g*e^(-lambda*dt)) ------
# AIOS_ALPHA_BM25=0.25
# AIOS_BETA_FAISS=0.45
# AIOS_GAMMA_RECENCY=0.30
# AIOS_LAMBDA_DECAY=0.05

# --- Memory compaction -----------------------------------------------------
# AIOS_MEMORY_COMPACT_UNVERIFIED_CHAT_DAYS=7
# AIOS_MEMORY_COMPACT_EPISODIC_DAYS=30
# AIOS_MEMORY_COMPACT_SEMANTIC_MAX_PER_TYPE=5000
# AIOS_MEMORY_COMPACT_WORKING_IDLE_MINUTES=60

# --- Skills (verified-skill reuse scoring) ---------------------------------
# AIOS_SKILL_LAMBDA_DECAY=0.005
# AIOS_SKILL_BONUS_MAX=0.2
# AIOS_SKILL_REUSE_BOOST_MAX=0.15
# AIOS_SKILL_REUSE_PENALTY_MAX=0.60
# AIOS_SKILL_REUSE_SUCCESS_K=3.0
# AIOS_SKILL_REUSE_FAILURE_K=1.5
# AIOS_SKILL_REUSE_FLOOR=0.25
# AIOS_SKILL_REUSE_DEMOTE_NET=3

# --- Earned autonomy / plan stage / narrative self --------------------------
# AIOS_EARNED_AUTONOMY=true            # let a verified-clean action class auto-grant future writes
# AIOS_EARNED_AUTONOMY_MIN_SUCCESSES=5
# AIOS_PLAN_STAGE=true                 # run the deterministic Planner + surface a `plan` SSE event on every non-reflex turn
# AIOS_NARRATIVE_SELF=true             # inject the verified-only autobiographical self-model into recalled context

# --- Ant-colony swarm --------------------------------------------------------
# AIOS_SWARM_MAX_WORKERS=4
# AIOS_SWARM_WORKER_CONCURRENCY=1
# AIOS_SWARM_REDUNDANCY=1
# AIOS_SWARM_CLOUD_BURST=true
# AIOS_SWARM_WORKER_BACKEND=auto
# AIOS_SWARM_PHEROMONE_FIDELITY=fast
# AIOS_SWARM_CONFLICT_STRATEGY=merge
# AIOS_SWARM_CONFLICT_TIMEOUT_S=30
# AIOS_SWARM_SCOUT_TEMPERATURE=adaptive:1.0:0.01:0.95
# AIOS_SWARM_SCOUT_EXPLORATION_BONUS=1.414
# AIOS_SWARM_ADAPTIVE_SIZING=true
# AIOS_SWARM_MIN_WORKERS=1
# AIOS_SWARM_MEMORY_PER_WORKER_MB=256
# AIOS_RESOURCE_MODE=normal            # normal | conserve | hibernate

# --- Security / human-in-the-loop --------------------------------------------
# AIOS_CONFIDENCE_THRESHOLD=0.72
# AIOS_MAX_RED_ACTIONS=3
# AIOS_YELLOW_TIMEOUT_MS=60000
# AIOS_RED_TIMEOUT_MS=30000
# Executor writable roots (delimited by ';' on Windows). Defaults to the
# training_ground + lab "playground" dirs when unset.
# AIOS_SCOPE_ROOTS=C:\Users\kumar\ai-editor\training_ground
# AIOS_VERIFY_RUNNER=python -m pytest
# Approved arbitrary-code commands can use a fail-closed Docker backend.
# Build once: docker build -f Dockerfile.executor -t aios-executor:local .
# AIOS_APPROVED_EXECUTION_BACKEND=container
# AIOS_CONTAINER_RUNTIME=docker
# AIOS_CONTAINER_IMAGE=aios-executor:local
# AIOS_CONTAINER_MEMORY_MB=1024
# AIOS_CONTAINER_CPUS=1
# AIOS_CONTAINER_PIDS_LIMIT=128
# AIOS_MAX_COMMAND_CHARS=8192
# AIOS_MAX_COMMAND_OUTPUT_BYTES=1048576
# Keep loopback for zero-config local use. Non-loopback API_HOST requires a token.
# AIOS_API_HOST=127.0.0.1
# AIOS_API_PORT=8000
# AIOS_API_TOKEN=generate-a-random-token-of-at-least-32-characters
# Frontend deployment must receive the same value as VITE_AIOS_API_TOKEN.
# AIOS_TRUST_PROXY_HEADERS=false       # only set true behind a trusted reverse proxy
# AIOS_TRUSTED_PROXIES=                # comma-separated proxy IPs, required if TRUST_PROXY_HEADERS=true
# AIOS_ENABLE_DOCS=false               # serve /docs (Swagger UI) — leave off in production
# AIOS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000,http://127.0.0.1:3000
# AIOS_PROBE_BASE=http://127.0.0.1:8000   # base URL the operator-authorized probe/curriculum drivers hit
#
# --- Optional: vector prompt-injection shield (loads the embedder; needs RAM) -
# AIOS_INJECTION_VECTOR_SHIELD=false
# AIOS_INJECTION_VECTOR_THRESHOLD=0.6

# --- Internet browse tool ----------------------------------------------------
# The browse tool is always YELLOW (human approval per URL). No env needed to
# enable it; it is advertised to the agent when its role allows network tools.

# --- Local LLM (Ollama) ------------------------------------------------------
# OLLAMA_HOST=http://127.0.0.1:11434
# AIOS_LLM_MODEL=qwen2.5-coder
# AIOS_LLM_TIMEOUT_S=120
# AIOS_LLM_TEMPERATURE=0.1
# AIOS_LLM_NUM_CTX=4096

# --- Turn behavior toggles ---------------------------------------------------
# AIOS_INDEX_CHAT=true                 # index chat turns into episodic memory
# AIOS_REFLECT_ON_FAILURE=true         # run the reflection agent after a verified failure
# AIOS_INTERPRET_ALIGNMENT=true        # run alignment interpretation on generated turns
# AIOS_OFFLINE_MODE=false              # force local-only, refuse any cloud route regardless of provider config

# --- Optional cloud fallback (AWS Bedrock) — leave blank for pure local-first -
# Setting a region turns Bedrock ON (the model has a sensible default). Auth uses
# a Bedrock API key — the new BEARER TOKEN (starts ABSK...), NOT an IAM AKIA... key
# — read from the environment only, never written to disk. Then pick a "Cloud
# (Bedrock)" model in the UI to route a turn to Bedrock.
# AIOS_BEDROCK_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=ABSK...your-bedrock-api-key...
# AIOS_BEDROCK_MODEL=amazon.nova-pro-v1:0   # optional; default amazon.nova-lite-v1:0
# AIOS_BEDROCK_MAX_TOKENS=1024

# --- Optional cloud fallback (Google Gemini) — leave blank for pure local-first -
# Setting a project turns Gemini ON.
# AIOS_GEMINI_PROJECT=your-gcp-project-id
# AIOS_GEMINI_LOCATION=us-central1
# AIOS_GEMINI_MODEL=gemini-2.5-flash
# AIOS_GEMINI_MAX_TOKENS=1024
# AIOS_GEMINI_THINKING_BUDGET=0

# --- Optional cloud fallback (OpenAI-compatible: OpenAI, Groq, Together, vLLM, LM Studio) -
# Setting an API key turns this provider ON.
# AIOS_OPENAI_API_KEY=sk-...your-key...
# AIOS_OPENAI_BASE_URL=https://api.openai.com/v1
# AIOS_OPENAI_MODEL=gpt-4o-mini
# AIOS_OPENAI_MAX_TOKENS=1024

# --- Optional cloud fallback (Anthropic direct API) -------------------------
# Setting an API key turns this provider ON.
# AIOS_ANTHROPIC_API_KEY=sk-ant-...your-key...
# AIOS_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AIOS_ANTHROPIC_MAX_TOKENS=1024

# --- Multi-LLM router ---------------------------------------------------------
# AIOS_CLOUD_HISTORY_WINDOW=2
# AIOS_CLOUD_CODING_HISTORY_WINDOW=4
# Which task classes are cloud-eligible by default (reasoning/coding hit small
# local models' ceiling); "" forces local-only regardless of configured providers.
# AIOS_ROUTER_CLOUD_TASKS=reasoning,coding
# AIOS_ROUTER_PREFER_LOCAL=true
# AIOS_ROUTER_MAX_COST=high            # low | medium | high
# AIOS_ROUTER_LLM_PICK=true            # let the router's own LLM call pick among eligible models
# AIOS_ROUTER_CALIBRATION_WEIGHT=0.4

# --- Corrective-RAG (CRAG): metacognitive gate on memory recall --------------
# Deterministic and local by default; external/cloud sources below are
# independently opt-in and privacy-filtered. See
# docs/superpowers/specs/2026-06-29-crag-for-gagos-design.md.
# AIOS_CRAG=true
# AIOS_CRAG_UPPER=0.6
# AIOS_CRAG_LOWER=0.2
# AIOS_CRAG_EXTERNAL=false             # allow external corrective retrieval on low-confidence local recall
# AIOS_CRAG_CLOUD=false                # use the configured cloud model as a broader knowledge source
# AIOS_CRAG_LLM_JUDGE=false            # optional local-LLM relevance judge (caution-only, adds a model call per hit)
# AIOS_CRAG_WEBSEARCH=false            # real web-search provider (needs endpoint + key below)
# AIOS_CRAG_SEARCH_ENDPOINT=
# AIOS_CRAG_SEARCH_API_KEY=
# AIOS_CRAG_DOCUMENTS=true

# --- Knowledge ingestion (operator document uploads) -------------------------
# AIOS_KNOWLEDGE_MAX_UPLOAD_BYTES=10000000
# AIOS_KNOWLEDGE_CHUNK_MAX_TOKENS=300
# AIOS_KNOWLEDGE_CHUNK_OVERLAP_TOKENS=40

# --- Developmental curriculum --------------------------------------------------
# AIOS_CURRICULUM_FUZZY=true           # fuzzy lexical matching lets organically phrased turns count toward curriculum tasks
# AIOS_CURRICULUM_FUZZY_THRESHOLD=0.5

# --- Facts auto-extraction (supervised memory formation) ---------------------
# Extracts fact candidates from the OPERATOR'S OWN statements only; nothing
# reaches recall until a named human approves it.
# AIOS_FACTS_AUTO_EXTRACT=true
# AIOS_FACTS_AUTO_EXTRACT_MAX_PER_TURN=3

# --- Cortex bus (durable cold-path observation tier) --------------------------
# AIOS_CORTEX_BUS=true
# AIOS_CORTEX_BUS_RETENTION=10000
# AIOS_CORTEX_BUS_RETENTION_DAYS=7

# --- Voice (local/private STT + TTS) -------------------------------------------
# AIOS_VOICE_STT=false
# AIOS_VOICE_TTS=false
# AIOS_VOICE_STT_MODEL=base
# AIOS_VOICE_STT_DEVICE=auto           # auto | cpu | cuda
# AIOS_VOICE_STT_COMPUTE_TYPE=int8
# AIOS_VOICE_TTS_MODEL=en_US-lessac-medium
# AIOS_VOICE_MODELS_DIR=<AIOS_DATA_DIR>/voice_models
# AIOS_VOICE_MAX_AUDIO_BYTES=10485760

# --- Sovereign Roadmap: Phases 3B-7 (all default OFF; opt-in only) -----------
# AIOS_QUEEN_SERVICES=false
# AIOS_QUEEN_SERVICE_QUEUE_DEPTH=16
# AIOS_PHEROMONE_ENABLED=false
# AIOS_PHEROMONE_LAMBDA_DECAY=0.02
# AIOS_PHEROMONE_FLOOR=0.01
# AIOS_LIVE_SURFACE=false
# AIOS_WORKTREE_BACKEND=false
# AIOS_WORKTREE_ROOT=<AIOS_DATA_DIR>/worktrees
# AIOS_ROLLBACK_REGISTRY=false
# AIOS_ROLLBACK_RETENTION_DAYS=30
# AIOS_AUDIT_ANCHOR_API=false
# AIOS_SELF_CONSISTENCY=false
# AIOS_SELF_CONSISTENCY_N=3
# AIOS_POLICY_ENGINE=false

# --- Internal / test-only (do not set in normal operation) -------------------
# AIOS_WORKER_SANDBOX is set BY the Council Runtime worker subprocess itself
# (ControlledSubprocessBackend) to suppress re-loading .env after secrets have
# already been scrubbed from the child's environment. Setting it manually
# disables dotenv loading entirely.
# AIOS_WORKER_SANDBOX=1
