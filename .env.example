# ── AI OS (aios) environment overrides ───────────────────────────────────────
# Copy to `.env` and uncomment what you want to change. Every value is OPTIONAL:
# sensible local-first defaults live in aios/config.py, and anything left unset
# falls back to those. `.env` is gitignored — never commit real secrets.

# --- Paths -------------------------------------------------------------------
# AIOS_DATA_DIR=C:\Users\kumar\ai-editor\data

# --- Embeddings --------------------------------------------------------------
# AIOS_EMBEDDING_MODEL=all-MiniLM-L6-v2
# AIOS_EMBEDDING_DIM=384

# --- Hybrid retrieval weights  (R = a*BM25 + b*FAISS + g*e^(-lambda*dt)) ------
# AIOS_ALPHA_BM25=0.25
# AIOS_BETA_FAISS=0.45
# AIOS_GAMMA_RECENCY=0.30
# AIOS_LAMBDA_DECAY=0.05

# --- Security / human-in-the-loop --------------------------------------------
# AIOS_CONFIDENCE_THRESHOLD=0.72
# AIOS_MAX_RED_ACTIONS=3
# AIOS_YELLOW_TIMEOUT_MS=60000
# AIOS_RED_TIMEOUT_MS=30000
# Executor writable roots (delimited by ';' on Windows). Defaults to the
# training_ground "playground" when unset.
# AIOS_SCOPE_ROOTS=C:\Users\kumar\ai-editor\training_ground

# --- Local LLM (Ollama) ------------------------------------------------------
# OLLAMA_HOST=http://127.0.0.1:11434
# AIOS_LLM_MODEL=qwen2.5-coder

# --- Optional cloud fallback (AWS Bedrock) — leave blank for pure local-first -
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
